import { ListView, Palette } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { AccountItem, MailDetail } from "models.slint";
import {
    LabeledTextField, MButton, MaterialIcon, MIconButton, SettingsToggle, WideNavItem
} from "components.slint";
import { AccountMenuRow } from "shell.slint";

export component AccountMenuOverlay inherits Rectangle {
    in property <bool> wide-sidebar: true;
    in property <[AccountItem]> accounts;
    in property <string> active-account-id: "";
    in-out property <bool> account-menu-open: false;
    in-out property <bool> settings-open: false;
    in-out property <bool> detail-open: false;
    callback switch-account(string);
    callback open-account-setup;
    callback manage-account(string);

    z: 20;
    background: transparent;
    TouchArea { clicked => { root.account-menu-open = false; } }
    Rectangle {
        x: root.wide-sidebar ? 12px : 58px;
        y: parent.height < 520px ? 12px : 82px;
        width: 340px;
        height: parent.height < 520px ? parent.height - 24px : 414px;
        border-radius: 8px;
        border-width: 1px;
        border-color: Theme.outline;
        background: Theme.surface;
        accessible-role: complementary;
        accessible-label: "Account switcher";
        TouchArea { }
        VerticalLayout {
            padding: 12px;
            spacing: 3px;
            HorizontalLayout {
                height: 40px;
                Text { text: "Choose an account"; color: Theme.on-surface; font-family: Theme.body-font; font-size: 16px; font-weight: 500; vertical-alignment: center; horizontal-stretch: 1; }
                MIconButton { icon: "close"; label: "Close account switcher"; compact-visual: true; clicked => { root.account-menu-open = false; } }
            }
            account-list := ListView {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                for account in root.accounts: AccountMenuRow {
                    width: account-list.width;
                    account: account;
                    selected: root.active-account-id == account.id;
                    clicked(id) => { root.switch-account(id); root.account-menu-open = false; root.detail-open = false; }
                }
            }
            MButton {
                label: "Add account";
                variant: "filled";
                clicked => { root.account-menu-open = false; root.open-account-setup(); }
            }
            MButton {
                label: "Manage selected account";
                icon: "settings";
                variant: "tonal";
                enabled: root.active-account-id != "";
                clicked => { root.account-menu-open = false; root.manage-account(root.active-account-id); }
            }
            MButton { label: "Display settings"; icon: "settings"; clicked => { root.account-menu-open = false; root.settings-open = true; } }
        }
    }
}

export component AccountSetupOverlay inherits Rectangle {
    in-out property <bool> account-setup-open: false;
    in property <bool> operation-loading: false;
    in property <string> operation-stage: "";
    in-out property <string> operation-error: "";
    callback add-account(string, string, string, string, string, string);

    private property <string> account-name: "";
    private property <string> account-address: "";
    private property <string> account-password: "";
    private property <string> account-login: "";
    private property <string> account-host: "";
    private property <string> account-port: "993";
    private property <bool> server-settings-open: false;
    private property <bool> validation-visible: false;
    private property <bool> login-follows-address: true;
    private property <bool> required-fields-ready: root.account-name != "" && root.account-address != "" && root.account-password != "" && root.account-login != "" && root.account-host != "" && root.account-port != "";

    z: 32;
    background: Theme.scrim;
    TouchArea { }

    panel := Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: parent.width < 644px ? parent.width - 24px : 620px;
        height: root.server-settings-open ? (parent.height < 584px ? parent.height - 24px : 560px) : (parent.height < 504px ? parent.height - 24px : 470px);
        border-radius: 8px;
        border-width: 1px;
        border-color: Theme.outline;
        background: Theme.surface;
        accessible-role: form;
        accessible-label: root.operation-loading ? "Adding mail account. " + root.operation-stage : "Add a mail account";

        VerticalLayout {
            padding: 18px;
            spacing: 5px;

            HorizontalLayout {
                height: 48px;
                VerticalLayout {
                    alignment: center;
                    Text { text: "Add a mail account"; color: Theme.on-surface; font-family: Theme.body-font; font-size: 20px; font-weight: 600; }
                    Text { text: "Connect with an email address and app password."; color: Theme.on-surface-variant; font-family: Theme.body-font; font-size: 10px; }
                }
                Rectangle { horizontal-stretch: 1; }
                MIconButton {
                    icon: "close";
                    label: "Close account setup";
                    busy: root.operation-loading;
                    clicked => { root.account-setup-open = false; }
                }
            }

            HorizontalLayout {
                spacing: 10px;
                LabeledTextField {
                    horizontal-stretch: 1;
                    label: "Account name";
                    placeholder: "Personal";
                    value <=> root.account-name;
                    enabled: !root.operation-loading;
                    error: root.validation-visible && root.account-name == "" ? "Enter an account name" : "";
                }
                LabeledTextField {
                    horizontal-stretch: 1;
                    label: "Email address";
                    placeholder: "you@example.com";
                    value <=> root.account-address;
                    enabled: !root.operation-loading;
                    error: root.validation-visible && root.account-address == "" ? "Enter an email address" : "";
                    edited(value) => {
                        if (root.login-follows-address) { root.account-login = value; }
                    }
                }
            }

            LabeledTextField {
                label: "App password";
                placeholder: "Password from your email provider";
                helper: "Stored in your system credential service, not the mailbox database.";
                value <=> root.account-password;
                enabled: !root.operation-loading;
                input-type: InputType.password;
                error: root.validation-visible && root.account-password == "" ? "Enter an app password" : "";
            }

            LabeledTextField {
                label: "IMAP host";
                placeholder: "imap.example.com";
                value <=> root.account-host;
                enabled: !root.operation-loading;
                error: root.validation-visible && root.account-host == "" ? "Enter the IMAP host" : "";
            }

            MButton {
                label: root.server-settings-open ? "Hide server settings" : "Server settings";
                icon: root.server-settings-open ? "expand_less" : "expand_more";
                variant: "tonal";
                enabled: !root.operation-loading;
                clicked => { root.server-settings-open = !root.server-settings-open; }
            }

            if root.server-settings-open: HorizontalLayout {
                spacing: 10px;
                LabeledTextField {
                    horizontal-stretch: 1;
                    label: "IMAP login";
                    placeholder: "Usually your full email address";
                    value <=> root.account-login;
                    enabled: !root.operation-loading;
                    error: root.validation-visible && root.account-login == "" ? "Enter the IMAP login" : "";
                    edited(value) => { root.login-follows-address = value == ""; }
                }
                LabeledTextField {
                    width: 112px;
                    label: "Port";
                    placeholder: "993";
                    value <=> root.account-port;
                    enabled: !root.operation-loading;
                    error: root.validation-visible && root.account-port == "" ? "Enter a port" : "";
                }
            }

            if root.operation-loading || root.operation-error != "": Rectangle {
                height: 42px;
                border-radius: 4px;
                background: root.operation-error != "" ? Theme.error-container : Theme.primary-container;
                accessible-role: region;
                accessible-live-region: polite;
                accessible-label: root.operation-error != "" ? "Account could not be added. " + root.operation-error : root.operation-stage;
                HorizontalLayout {
                    padding-left: 10px;
                    padding-right: 10px;
                    spacing: 8px;
                    MaterialIcon {
                        name: root.operation-error != "" ? "error" : "progress_activity";
                        width: 22px;
                        size: 18px;
                        icon-color: root.operation-error != "" ? Theme.error : Theme.primary;
                    }
                    Text {
                        text: root.operation-error != "" ? root.operation-error : root.operation-stage;
                        color: root.operation-error != "" ? Theme.on-error-container : Theme.on-primary-container;
                        font-family: Theme.body-font;
                        font-size: 11px;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        wrap: word-wrap;
                    }
                }
            }

            Rectangle { vertical-stretch: 1; }
            HorizontalLayout {
                spacing: 8px;
                Rectangle { horizontal-stretch: 1; }
                MButton {
                    label: "Cancel";
                    enabled: !root.operation-loading;
                    clicked => { root.account-setup-open = false; }
                }
                MButton {
                    label: "Add account";
                    variant: "filled";
                    loading: root.operation-loading;
                    clicked => {
                        root.validation-visible = true;
                        if (root.required-fields-ready) {
                            root.add-account(root.account-name, root.account-address, root.account-login, root.account-host, root.account-port, root.account-password);
                            root.account-password = "";
                        } else {
                            root.server-settings-open = true;
                        }
                    }
                }
            }
        }
    }
}

export component AccountStatusOverlay inherits Rectangle {
    in-out property <bool> account-status-open: false;
    in-out property <bool> account-remove-open: false;
    in property <bool> operation-loading: false;
    in property <string> operation-stage: "";
    in-out property <string> operation-error: "";
    in property <string> account-id: "";
    in property <string> account-name: "";
    in property <string> account-address: "";
    in property <string> account-status: "Not checked";
    in property <bool> account-has-error: false;
    callback diagnose-account(string);
    callback cancel-operation;

    z: 34;
    background: Theme.scrim;
    TouchArea { }
    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: parent.width < 564px ? parent.width - 24px : 540px;
        height: parent.height < 464px ? parent.height - 24px : 440px;
        border-radius: 8px;
        border-width: 1px;
        border-color: Theme.outline;
        background: Theme.surface;
        accessible-role: region;
        accessible-label: "Account status for " + root.account-name + ". " + root.account-status;
        VerticalLayout {
            padding: 20px;
            spacing: 10px;
            HorizontalLayout {
                height: 48px;
                VerticalLayout {
                    alignment: center;
                    Text { text: "Account status"; color: Theme.on-surface; font-family: Theme.body-font; font-size: 20px; font-weight: 600; }
                    Text { text: "Review and verify this mail connection."; color: Theme.on-surface-variant; font-family: Theme.body-font; font-size: 10px; }
                }
                Rectangle { horizontal-stretch: 1; }
                MIconButton { icon: "close"; label: "Close account status"; busy: root.operation-loading; clicked => { root.account-status-open = false; } }
            }

            Rectangle {
                height: 70px;
                border-radius: 6px;
                background: Theme.surface-container-low;
                HorizontalLayout {
                    padding-left: 14px;
                    padding-right: 14px;
                    spacing: 12px;
                    MaterialIcon { name: "account_circle"; width: 34px; size: 28px; icon-color: Theme.primary; }
                    VerticalLayout {
                        alignment: center;
                        spacing: 2px;
                        Text { text: root.account-name; color: Theme.on-surface; font-family: Theme.body-font; font-size: 14px; font-weight: 500; overflow: elide; }
                        Text { text: root.account-address; color: Theme.on-surface-variant; font-family: Theme.body-font; font-size: 11px; overflow: elide; }
                    }
                }
            }

            Rectangle {
                height: 82px;
                border-radius: 6px;
                border-width: 1px;
                border-color: root.account-has-error || root.operation-error != "" ? Theme.error : Theme.outline-variant;
                background: root.account-has-error || root.operation-error != "" ? Theme.error-container : Theme.surface-container;
                accessible-role: region;
                accessible-live-region: polite;
                accessible-label: root.operation-loading ? (root.operation-stage == "" ? "Checking connection" : root.operation-stage) : root.operation-error != "" ? "Connection check failed. " + root.operation-error : (root.account-has-error ? "Connection needs attention. " : "Connection status. ") + root.account-status;
                HorizontalLayout {
                    padding: 14px;
                    spacing: 12px;
                    MaterialIcon {
                        name: root.operation-loading ? "progress_activity" : root.account-has-error || root.operation-error != "" ? "error" : "check_circle";
                        width: 26px;
                        size: 21px;
                        icon-color: root.account-has-error || root.operation-error != "" ? Theme.error : root.operation-loading ? Theme.primary : Theme.success;
                    }
                    VerticalLayout {
                        alignment: center;
                        spacing: 3px;
                        Text {
                            text: root.operation-loading ? (root.operation-stage == "" ? "Checking connection" : root.operation-stage) : root.operation-error != "" ? "Connection check failed" : root.account-has-error ? "Connection needs attention" : "Connection ready";
                            color: root.account-has-error || root.operation-error != "" ? Theme.on-error-container : Theme.on-surface;
                            font-family: Theme.body-font;
                            font-size: 12px;
                            font-weight: 500;
                        }
                        Text {
                            text: root.operation-error != "" ? root.operation-error : root.account-status;
                            color: root.account-has-error || root.operation-error != "" ? Theme.on-error-container : Theme.on-surface-variant;
                            font-family: Theme.body-font;
                            font-size: 10px;
                            wrap: word-wrap;
                        }
                    }
                }
            }

            Text {
                text: "Connection checks verify TLS, sign-in, IMAP support, and read-only access to Inbox.";
                color: Theme.on-surface-variant;
                font-family: Theme.body-font;
                font-size: 10px;
                wrap: word-wrap;
            }
            Rectangle { vertical-stretch: 1; }
            HorizontalLayout {
                spacing: 8px;
                MButton {
                    label: "Remove account";
                    icon: "delete";
                    variant: "danger";
                    enabled: !root.operation-loading && root.account-id != "";
                    clicked => { root.operation-error = ""; root.account-remove-open = true; }
                }
                Rectangle { horizontal-stretch: 1; }
                if root.operation-loading: MButton { label: "Cancel check"; clicked => { root.cancel-operation(); } }
                MButton {
                    label: "Check connection";
                    icon: "progress_activity";
                    variant: "filled";
                    enabled: root.account-id != "";
                    loading: root.operation-loading;
                    clicked => { root.diagnose-account(root.account-id); }
                }
            }
        }
    }
}

export component AccountRemoveDialog inherits Rectangle {
    in-out property <bool> account-remove-open: false;
    in property <bool> operation-loading: false;
    in property <string> operation-stage: "";
    in-out property <string> operation-error: "";
    in property <string> account-id: "";
    in property <string> account-name: "";
    in property <string> account-address: "";
    callback remove-account(string);

    z: 46;
    background: Theme.scrim;
    TouchArea { }
    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: parent.width < 484px ? parent.width - 24px : 460px;
        height: 292px;
        border-radius: 8px;
        border-width: 1px;
        border-color: Theme.outline;
        background: Theme.surface;
        accessible-role: region;
        accessible-label: "Confirm removing " + root.account-name + " from Nivalis Mail";
        VerticalLayout {
            padding: 20px;
            spacing: 10px;
            MaterialIcon { name: "delete"; width: 32px; height: 32px; size: 24px; icon-color: Theme.error; }
            Text { text: "Remove this account?"; color: Theme.on-surface; font-family: Theme.body-font; font-size: 18px; font-weight: 600; }
            Text {
                text: root.account-name + " (" + root.account-address + ") will be removed from this device. Messages kept only in its local cache may no longer be available.";
                color: Theme.on-surface-variant;
                font-family: Theme.body-font;
                font-size: 11px;
                wrap: word-wrap;
            }
            if root.operation-error != "": Text {
                text: root.operation-error + " The account was not removed; try again.";
                color: Theme.error;
                font-family: Theme.body-font;
                font-size: 10px;
                wrap: word-wrap;
                accessible-role: region;
                accessible-live-region: assertive;
            }
            Rectangle { vertical-stretch: 1; }
            HorizontalLayout {
                spacing: 8px;
                Rectangle { horizontal-stretch: 1; }
                MButton {
                    label: "Keep account";
                    enabled: !root.operation-loading;
                    clicked => { root.account-remove-open = false; }
                }
                MButton {
                    label: root.operation-loading ? (root.operation-stage == "" ? "Removing account" : root.operation-stage) : "Remove account";
                    icon: "delete";
                    variant: "danger-filled";
                    enabled: root.account-id != "";
                    loading: root.operation-loading;
                    clicked => { root.remove-account(root.account-id); }
                }
            }
        }
    }
}

export component FilterMenuOverlay inherits Rectangle {
    in property <length> navigation-width: 248px;
    in property <bool> compact-layout: false;
    in property <bool> wide-sidebar: true;
    in property <string> active-folder: "Inbox";
    in-out property <bool> filter-menu-open: false;
    callback filter-folder(string);

    z: 21;
    background: transparent;
    TouchArea { clicked => { root.filter-menu-open = false; } }
    Rectangle {
        x: root.navigation-width + (root.compact-layout ? parent.width - root.navigation-width - 220px : (root.wide-sidebar ? 188px : 152px));
        y: 144px;
        width: 210px;
        height: 206px;
        border-radius: 8px;
        border-width: 1px;
        border-color: Theme.outline;
        background: Theme.surface;
        TouchArea { }
        VerticalLayout {
            padding: 9px;
            spacing: 2px;
            Text { text: "Filter messages"; color: Theme.on-surface; font-family: Theme.body-font; font-size: 12px; font-weight: 500; height: 30px; vertical-alignment: center; }
            WideNavItem { icon: "inbox"; label: "All inbox mail"; selected: root.active-folder == "Inbox"; clicked => { root.filter-folder("Inbox"); root.filter-menu-open = false; } }
            WideNavItem { icon: "mark_email_unread"; label: "Unread only"; selected: root.active-folder == "Unread"; clicked => { root.filter-folder("Unread"); root.filter-menu-open = false; } }
            WideNavItem { icon: "star"; label: "Starred only"; selected: root.active-folder == "Starred"; clicked => { root.filter-folder("Starred"); root.filter-menu-open = false; } }
        }
    }
}

export component InboxMoreMenuOverlay inherits Rectangle {
    in property <length> navigation-width: 248px;
    in property <bool> compact-layout: false;
    in property <bool> wide-sidebar: true;
    in-out property <bool> more-menu-open: false;
    in-out property <bool> account-menu-open: false;
    in-out property <bool> settings-open: false;

    z: 22;
    background: transparent;
    TouchArea { clicked => { root.more-menu-open = false; } }
    Rectangle {
        x: root.navigation-width + (root.compact-layout ? parent.width - root.navigation-width - 226px : (root.wide-sidebar ? 178px : 142px));
        y: 88px;
        width: 218px;
        height: 116px;
        border-radius: 8px;
        border-width: 1px;
        border-color: Theme.outline;
        background: Theme.surface;
        TouchArea { }
        VerticalLayout {
            padding: 9px;
            spacing: 2px;
            MButton { label: "Account status"; icon: "account_circle"; clicked => { root.more-menu-open = false; root.account-menu-open = true; } }
            MButton { label: "Display settings"; icon: "settings"; clicked => { root.more-menu-open = false; root.settings-open = true; } }
        }
    }
}

export component SettingsOverlay inherits Rectangle {
    in-out property <bool> settings-open: false;
    in-out property <bool> dark-mode: false;
    in-out property <bool> high-contrast: false;
    in-out property <bool> reduced-motion: false;

    z: 24;
    background: Theme.scrim;
    TouchArea { clicked => { root.settings-open = false; } }
    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: parent.width < 540px ? parent.width - 24px : 500px;
        height: 392px;
        border-radius: 8px;
        border-width: 1px;
        border-color: Theme.outline;
        background: Theme.surface;
        accessible-role: region;
        accessible-label: "Display preferences";
        TouchArea { }
        VerticalLayout {
            padding: 20px;
            spacing: 6px;
            HorizontalLayout {
                height: 48px;
                VerticalLayout {
                    alignment: center;
                    Text { text: "Display preferences"; color: Theme.on-surface; font-family: Theme.body-font; font-size: 18px; font-weight: 500; }
                    Text { text: "Make mail comfortable to read."; color: Theme.on-surface-variant; font-family: Theme.body-font; font-size: 10px; }
                }
                Rectangle { horizontal-stretch: 1; }
                MIconButton { icon: "close"; label: "Close settings"; clicked => { root.settings-open = false; } }
            }
            SettingsToggle {
                icon: "dark_mode";
                label: "Dark theme";
                description: "Use darker surfaces in low light";
                checked <=> root.dark-mode;
                toggled(value) => {
                    Theme.dark-mode = value;
                    Palette.color-scheme = value ? ColorScheme.dark : ColorScheme.light;
                }
            }
            SettingsToggle {
                icon: "contrast";
                label: "High contrast";
                description: "Strengthen text, outlines, and focus rings";
                checked <=> root.high-contrast;
                toggled(value) => { Theme.high-contrast = value; }
            }
            SettingsToggle {
                icon: "motion_photos_off";
                label: "Reduce motion";
                description: "Use immediate state changes";
                checked <=> root.reduced-motion;
                toggled(value) => { Theme.reduced-motion = value; }
            }
            Rectangle { vertical-stretch: 1; }
            HorizontalLayout {
                Rectangle { horizontal-stretch: 1; }
                MButton { label: "Close preferences"; variant: "tonal"; clicked => { root.settings-open = false; } }
            }
        }
    }
}

export component MessageMenuOverlay inherits Rectangle {
    in property <bool> compact-layout: false;
    in property <bool> mail-actions-enabled: true;
    in property <bool> mutation-loading: false;
    in property <MailDetail> selected-mail;
    in property <string> selected-id: "";
    in property <string> active-folder: "Inbox";
    in-out property <bool> message-menu-open: false;
    in-out property <bool> delete-dialog-open: false;
    callback toggle-star(string);
    callback mark-unread(string);

    z: 25;
    background: transparent;
    TouchArea { clicked => { root.message-menu-open = false; } }
    Rectangle {
        x: parent.width - self.width - 16px;
        y: root.compact-layout ? 104px : 202px;
        width: 232px;
        height: 160px;
        border-radius: 8px;
        border-width: 1px;
        border-color: Theme.outline;
        background: Theme.surface;
        TouchArea { }
        VerticalLayout {
            padding: 8px;
            spacing: 2px;
            MButton {
                label: !root.mail-actions-enabled ? "Star unavailable (read-only)" : root.selected-mail.starred ? "Remove star" : "Add star";
                icon: root.selected-mail.starred ? "star" : "star_outline";
                enabled: root.mail-actions-enabled;
                loading: root.mutation-loading;
                clicked => { root.toggle-star(root.selected-id); root.message-menu-open = false; }
            }
            MButton {
                label: !root.mail-actions-enabled ? "Unread unavailable (read-only)" : "Mark unread";
                icon: "mark_email_unread";
                enabled: root.mail-actions-enabled;
                loading: root.mutation-loading;
                clicked => { root.mark-unread(root.selected-id); root.message-menu-open = false; }
            }
            MButton {
                label: !root.mail-actions-enabled ? "Delete unavailable (read-only)" : root.active-folder == "Trash" ? "Delete permanently" : "Move to trash";
                icon: "delete";
                variant: "danger";
                enabled: root.mail-actions-enabled;
                loading: root.mutation-loading;
                clicked => { root.message-menu-open = false; root.delete-dialog-open = true; }
            }
        }
    }
}

export component DeleteDialog inherits Rectangle {
    in property <string> active-folder: "Inbox";
    in property <string> selected-id: "";
    in property <bool> mail-actions-enabled: true;
    in property <bool> mutation-loading: false;
    in-out property <bool> delete-dialog-open: false;
    callback delete-mail(string);

    z: 40;
    background: Theme.scrim;
    TouchArea { }
    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: parent.width < 460px ? parent.width - 24px : 420px;
        height: 234px;
        border-radius: 8px;
        border-width: 1px;
        border-color: Theme.outline;
        background: Theme.surface;
        accessible-role: region;
        accessible-label: !root.mail-actions-enabled ? "Delete is unavailable while mail is read-only" : root.mutation-loading ? "Message change in progress" : root.active-folder == "Trash" ? "Confirm permanently deleting this message" : "Confirm moving this message to trash";
        VerticalLayout {
            padding: 20px;
            spacing: 10px;
            MaterialIcon { name: "delete"; width: 32px; height: 32px; size: 24px; icon-color: Theme.error; }
            Text { text: root.active-folder == "Trash" ? "Delete this message permanently?" : "Move this message to trash?"; color: Theme.on-surface; font-family: Theme.body-font; font-size: 18px; font-weight: 500; wrap: word-wrap; }
            Text {
                text: !root.mail-actions-enabled ? "Message changes are unavailable while the current mail source is read-only." : root.mutation-loading ? "Wait for the current message change to finish." : root.active-folder == "Trash" ? "This cannot be undone. The message will be removed from the local mailbox." : "You can undo this action from the confirmation message.";
                color: Theme.on-surface-variant;
                font-family: Theme.body-font;
                font-size: 11px;
                wrap: word-wrap;
            }
            Rectangle { vertical-stretch: 1; }
            HorizontalLayout {
                spacing: 8px;
                Rectangle { horizontal-stretch: 1; }
                MButton { label: "Keep message"; enabled: !root.mutation-loading; clicked => { root.delete-dialog-open = false; } }
                MButton {
                    label: !root.mail-actions-enabled ? "Delete unavailable (read-only)" : root.active-folder == "Trash" ? "Delete permanently" : "Move to trash";
                    icon: "delete";
                    variant: "danger-filled";
                    enabled: root.mail-actions-enabled;
                    loading: root.mutation-loading;
                    clicked => { root.delete-mail(root.selected-id); }
                }
            }
        }
    }
}

export component Snackbar inherits Rectangle {
    in property <length> window-width: 1200px;
    in property <length> window-height: 800px;
    in property <string> snackbar-text;
    in property <bool> snackbar-can-undo: false;
    in property <bool> undo-loading: false;
    in-out property <bool> snackbar-visible: false;
    callback undo-delete;

    z: 50;
    x: (root.window-width - self.width) / 2;
    y: root.window-height - self.height - 16px;
    width: root.window-width < 500px ? root.window-width - 24px : 460px;
    height: 56px;
    border-radius: 8px;
    border-width: 1px;
    border-color: Theme.outline;
    background: Theme.surface;
    accessible-role: region;
    accessible-live-region: polite;
    accessible-label: root.snackbar-text + (root.snackbar-can-undo ? (root.undo-loading ? ". Undo is loading." : ". Undo available.") : "");
    HorizontalLayout {
        padding-left: 12px;
        padding-right: 4px;
        spacing: 6px;
        MaterialIcon { name: "check_circle"; width: 22px; size: 19px; icon-color: Theme.success; }
        Text { text: root.snackbar-text; color: Theme.on-surface; font-family: Theme.body-font; font-size: 11px; font-weight: 400; vertical-alignment: center; horizontal-stretch: 1; overflow: elide; }
        if root.snackbar-can-undo: MButton { label: "Undo"; loading: root.undo-loading; clicked => { root.undo-delete(); } }
        MIconButton { icon: "close"; label: "Dismiss notification"; compact-visual: true; busy: root.undo-loading; clicked => { root.snackbar-visible = false; } }
    }
}
