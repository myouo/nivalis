import "../assets/fonts/MaterialSymbolsRounded-Subset.ttf";

import { Theme } from "theme.slint";
import { MailboxPane } from "mailbox.slint";
import { ReaderPane } from "reader.slint";
import { ComposerOverlay } from "composer.slint";
import {
    NavigationPane, TitleBar
} from "shell.slint";
import {
    AccountMenuOverlay, AccountRemoveDialog, AccountSetupOverlay, AccountStatusOverlay,
    DeleteDialog, FilterMenuOverlay, InboxMoreMenuOverlay, MessageMenuOverlay,
    SettingsOverlay, Snackbar
} from "overlays.slint";
import { MaterialIcon } from "components.slint";
import { EmptyState } from "states.slint";
import { AccountItem, MailDetail, MailSummary } from "models.slint";

export { AccountItem, MailDetail, MailSummary } from "models.slint";

export component AppWindow inherits Window {
    title: "Nivalis Mail";
    no-frame: true;
    preferred-width: 1200px;
    preferred-height: 800px;
    min-width: 680px;
    min-height: 560px;
    background: Theme.background;
    default-font-family: Theme.body-font;
    default-font-size: 12px;
    default-font-weight: 400;
    forward-focus: app-focus;

    in property <[MailSummary]> mails;
    in property <[AccountItem]> accounts;
    in property <MailDetail> selected-mail;
    in property <bool> has-accounts: true;
    in property <bool> compose-enabled: false;
    in property <bool> mail-actions-enabled: true;
    in property <bool> mutation-loading: false;
    in property <bool> undo-loading: false;
    in property <string> selected-id: "";
    in property <int> message-total: 0;
    in property <int> inbox-count: 0;
    in property <int> starred-count: 0;
    in property <int> draft-count: 0;
    in property <string> active-account-id: "";
    in property <string> active-account-name: "All inboxes";
    in property <string> data-source-label: "Local cache";
    in property <string> active-account-detail: "No account selected";
    in property <string> active-account-initials: "AI";
    in property <color> active-account-color: Theme.primary;
    in property <bool> active-account-error: true;
    in property <string> active-folder: "Inbox";
    in-out property <string> search-query: "";
    in-out property <bool> composer-open: false;
    in-out property <string> compose-to: "";
    in-out property <string> compose-subject: "";
    in-out property <string> compose-body: "";
    in-out property <string> composer-error: "";
    in property <bool> composer-loading: false;
    in property <string> composer-status: "";
    in-out property <bool> detail-open: false;
    in-out property <bool> initial-loading: false;
    in property <bool> mailbox-loading: false;
    in property <bool> has-previous-mailbox-page: false;
    in property <bool> has-next-mailbox-page: false;
    in property <bool> mailbox-navigation-loading: false;
    in property <int> mailbox-page-number: 1;
    in property <bool> mailbox-error: false;
    in property <string> mailbox-error-title: "";
    in property <string> mailbox-error-detail: "";
    in property <bool> total-known: true;
    in property <bool> detail-loading: false;
    in property <bool> detail-error: false;
    in property <string> detail-error-title: "";
    in property <string> detail-error-detail: "";
    in-out property <string> status-text: "Local cache";
    in-out property <bool> account-menu-open: false;
    in-out property <bool> account-setup-open: false;
    in-out property <bool> account-status-open: false;
    in-out property <bool> account-remove-open: false;
    in property <bool> account-operation-loading: false;
    in property <bool> sync-loading: false;
    in property <string> account-operation-stage: "";
    in-out property <string> account-operation-error: "";
    in property <string> managed-account-id: "";
    in property <string> managed-account-name: "";
    in property <string> managed-account-address: "";
    in property <string> managed-account-status: "Not checked";
    in property <bool> managed-account-has-error: false;
    in-out property <bool> settings-open: false;
    in-out property <bool> more-menu-open: false;
    in-out property <bool> message-menu-open: false;
    in-out property <bool> delete-dialog-open: false;
    in-out property <bool> snackbar-visible: false;
    in-out property <string> snackbar-text: "";
    in-out property <bool> snackbar-can-undo: false;
    in-out property <bool> dark-mode: false;
    in-out property <bool> high-contrast: false;
    in-out property <bool> reduced-motion: false;

    private property <bool> compact-layout: false;
    private property <bool> wide-sidebar: true;
    private property <bool> short-window: false;
    private property <length> navigation-width: 248px;
    private property <bool> sidebar-collapsed: false;
    private property <bool> filter-menu-open: false;
    private property <bool> error-banner-dismissed: false;
    private property <bool> is-maximized: false;
    private property <bool> blocking-overlay-open: root.account-menu-open
        || root.account-setup-open
        || root.account-status-open
        || root.account-remove-open
        || root.settings-open
        || root.more-menu-open
        || root.filter-menu-open
        || root.message-menu-open
        || root.composer-open
        || root.delete-dialog-open;

    changed width => {
        root.compact-layout = root.width < 760px;
        root.wide-sidebar = root.width >= 1080px && !root.sidebar-collapsed;
        root.navigation-width = root.wide-sidebar ? 248px : 54px;
    }
    changed height => { root.short-window = root.height < 660px; }
    changed sidebar-collapsed => {
        root.wide-sidebar = root.width >= 1080px && !root.sidebar-collapsed;
        root.navigation-width = root.wide-sidebar ? 248px : 54px;
    }
    changed active-account-id => { root.error-banner-dismissed = false; }

    callback select-mail(string);
    callback filter-folder(string);
    callback query-mail(string);
    callback toggle-star(string);
    callback archive(string);
    callback delete-mail(string);
    callback mark-unread(string);
    callback retry-mailbox;
    callback previous-mailbox-page;
    callback next-mailbox-page;
    callback retry-detail;
    callback send-message(string, string, string);
    callback save-draft(string, string, string);
    callback switch-account(string);
    callback add-account(string, string, string, string, string, string, string, string);
    callback manage-account(string);
    callback diagnose-account(string);
    callback sync-account(string);
    callback remove-account(string);
    callback cancel-account-operation;
    callback undo-delete;
    callback window-minimize;
    callback window-maximize(bool);
    callback window-close;
    callback window-drag;

    app-focus := FocusScope {
        focus-on-tab-navigation: false;

        KeyBinding {
            keys: @keys(Control + N);
            activated => {
                if (root.compose-enabled && !root.blocking-overlay-open) {
                    root.composer-error = "";
                    root.composer-open = true;
                }
            }
        }

        key-pressed(event) => {
            if (event.text == Key.Escape) {
                if (root.account-remove-open) {
                    if (!root.account-operation-loading) { root.account-remove-open = false; }
                }
                else if (root.account-setup-open) {
                    if (!root.account-operation-loading) { root.account-setup-open = false; }
                }
                else if (root.account-status-open) {
                    if (root.account-operation-loading) { root.cancel-account-operation(); }
                    else { root.account-status-open = false; }
                }
                else if (root.delete-dialog-open) {
                    if (!root.mutation-loading) { root.delete-dialog-open = false; }
                }
                else if (root.composer-open) {
                    if (!root.composer-loading) {
                        root.save-draft(root.compose-to, root.compose-subject, root.compose-body);
                    }
                }
                else if (root.message-menu-open) { root.message-menu-open = false; }
                else if (root.account-menu-open) { root.account-menu-open = false; }
                else if (root.settings-open) { root.settings-open = false; }
                else if (root.filter-menu-open) { root.filter-menu-open = false; }
                else if (root.more-menu-open) { root.more-menu-open = false; }
                else if (root.compact-layout && root.detail-open) { root.detail-open = false; }
                else { return reject; }
                return accept;
            }
            return reject;
        }

        outer-frame := Rectangle {
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.outline;
            background: Theme.background;
            clip: true;

            VerticalLayout {
                spacing: 0px;

                TitleBar {
                    dark-mode <=> root.dark-mode;
                    is-maximized <=> root.is-maximized;
                    minimize => { root.window-minimize(); }
                    maximize(value) => { root.window-maximize(value); }
                    close => { root.window-close(); }
                    drag => { root.window-drag(); }
                }

                HorizontalLayout {
                    spacing: 0px;
                    vertical-stretch: 1;

                    NavigationPane {
                        pane-width: root.navigation-width;
                        wide: root.wide-sidebar;
                        account-name: root.active-account-name;
                        account-detail: root.active-account-detail;
                        account-initials: root.active-account-initials;
                        account-color: root.active-account-color;
                        account-error: root.active-account-error;
                        compose-enabled: root.compose-enabled;
                        account-menu-open: root.account-menu-open;
                        settings-open: root.settings-open;
                        active-folder: root.active-folder;
                        inbox-count: root.inbox-count;
                        starred-count: root.starred-count;
                        draft-count: root.draft-count;
                        collapsed(value) => { root.sidebar-collapsed = value; }
                        compose => {
                            if (root.compose-enabled) {
                                root.composer-error = "";
                                root.composer-open = true;
                            }
                        }
                        folder-selected(folder) => { root.filter-folder(folder); root.detail-open = false; }
                        open-accounts => { root.account-menu-open = true; }
                        open-settings => { root.settings-open = true; }
                    }

                    workspace := Rectangle {
                        horizontal-stretch: 1;
                        background: Theme.surface;
                        border-top-left-radius: 8px;
                        clip: true;
                        accessible-role: main;
                        accessible-label: "Mail workspace";

                        if !root.has-accounts && (root.initial-loading || root.mailbox-loading): Rectangle {
                            accessible-role: progress-indicator;
                            accessible-label: "Loading local mail accounts";
                            VerticalLayout {
                                alignment: center;
                                spacing: 8px;
                                MaterialIcon { name: "progress_activity"; height: 38px; size: 26px; icon-color: Theme.primary; }
                                Text { text: "Loading local mail..."; color: Theme.on-surface-variant; font-family: Theme.body-font; font-size: 11px; horizontal-alignment: center; }
                            }
                        }

                        if !root.has-accounts && !root.initial-loading && !root.mailbox-loading && root.mailbox-error: EmptyState {
                            title: root.mailbox-error-title;
                            detail: root.mailbox-error-detail;
                            icon: "warning";
                            action-label: "Try again";
                            action => { root.retry-mailbox(); }
                        }

                        if !root.has-accounts && !root.initial-loading && !root.mailbox-loading && !root.mailbox-error: EmptyState {
                            title: "No mail accounts";
                            detail: "Add an account to check its connection and start receiving mail.";
                            icon: "account_circle";
                            action-label: "Add account";
                            action-variant: "filled";
                            action => { root.account-operation-error = ""; root.account-setup-open = true; }
                        }

                        if root.has-accounts: HorizontalLayout {
                            spacing: 0px;

                            if !root.compact-layout || !root.detail-open: MailboxPane {
                                compact-layout: root.compact-layout;
                                wide-sidebar: root.wide-sidebar;
                                active-folder: root.active-folder;
                                active-account-name: root.active-account-name;
                                data-source-label: root.data-source-label;
                                active-account-id: root.active-account-id;
                                active-account-error: root.active-account-error;
                                inbox-count: root.inbox-count;
                                status-text: root.status-text;
                                initial-loading: root.initial-loading;
                                mailbox-loading: root.mailbox-loading;
                                has-previous-mailbox-page: root.has-previous-mailbox-page;
                                has-next-mailbox-page: root.has-next-mailbox-page;
                                mailbox-navigation-loading: root.mailbox-navigation-loading;
                                mailbox-page-number: root.mailbox-page-number;
                                mailbox-error: root.mailbox-error;
                                mailbox-error-title: root.mailbox-error-title;
                                mailbox-error-detail: root.mailbox-error-detail;
                                total-known: root.total-known;
                                mail-actions-enabled: root.mail-actions-enabled;
                                mutation-loading: root.mutation-loading;
                                sync-loading: root.sync-loading;
                                mails: root.mails;
                                selected-id: root.selected-id;
                                message-total: root.message-total;
                                search-query <=> root.search-query;
                                detail-open <=> root.detail-open;
                                account-menu-open <=> root.account-menu-open;
                                more-menu-open <=> root.more-menu-open;
                                filter-menu-open <=> root.filter-menu-open;
                                error-banner-dismissed <=> root.error-banner-dismissed;
                                select-mail(id) => { root.select-mail(id); }
                                query-mail(query) => { root.query-mail(query); }
                                toggle-star(id) => { root.toggle-star(id); }
                                sync-account(id) => { root.sync-account(id); }
                                retry => { root.retry-mailbox(); }
                                previous-mailbox-page => { root.previous-mailbox-page(); }
                                next-mailbox-page => { root.next-mailbox-page(); }
                            }

                            if !root.compact-layout || root.detail-open: ReaderPane {
                                compact-layout: root.compact-layout;
                                window-width: root.width;
                                mail-actions-enabled: root.mail-actions-enabled;
                                mutation-loading: root.mutation-loading;
                                detail-loading: root.detail-loading;
                                detail-error: root.detail-error;
                                detail-error-title: root.detail-error-title;
                                detail-error-detail: root.detail-error-detail;
                                selected-id: root.selected-id;
                                selected-mail: root.selected-mail;
                                detail-open <=> root.detail-open;
                                delete-dialog-open <=> root.delete-dialog-open;
                                message-menu-open <=> root.message-menu-open;
                                filter-folder(folder) => { root.filter-folder(folder); }
                                toggle-star(id) => { root.toggle-star(id); }
                                archive(id) => { root.archive(id); }
                                mark-unread(id) => { root.mark-unread(id); }
                                retry-detail => { root.retry-detail(); }
                            }
                        }
                    }
                }
            }
        }
    }

    if root.account-menu-open: AccountMenuOverlay {
        width: parent.width;
        height: parent.height;
        wide-sidebar: root.wide-sidebar;
        accounts: root.accounts;
        active-account-id: root.active-account-id;
        account-menu-open <=> root.account-menu-open;
        settings-open <=> root.settings-open;
        detail-open <=> root.detail-open;
        switch-account(id) => { root.switch-account(id); }
        open-account-setup => { root.account-operation-error = ""; root.account-setup-open = true; }
        manage-account(id) => {
            root.manage-account(id);
            root.account-status-open = true;
        }
    }

    if root.account-setup-open: AccountSetupOverlay {
        width: parent.width;
        height: parent.height;
        account-setup-open <=> root.account-setup-open;
        operation-loading: root.account-operation-loading;
        operation-stage: root.account-operation-stage;
        operation-error <=> root.account-operation-error;
        add-account(name, address, login, imap-host, imap-port, smtp-host, smtp-port, password) => {
            root.add-account(name, address, login, imap-host, imap-port, smtp-host, smtp-port, password);
        }
    }

    if root.account-status-open: AccountStatusOverlay {
        width: parent.width;
        height: parent.height;
        account-status-open <=> root.account-status-open;
        account-remove-open <=> root.account-remove-open;
        operation-loading: root.account-operation-loading;
        operation-stage: root.account-operation-stage;
        operation-error <=> root.account-operation-error;
        account-id: root.managed-account-id;
        account-name: root.managed-account-name;
        account-address: root.managed-account-address;
        account-status: root.managed-account-status;
        account-has-error: root.managed-account-has-error;
        diagnose-account(id) => { root.diagnose-account(id); }
        cancel-operation => { root.cancel-account-operation(); }
    }

    if root.account-remove-open: AccountRemoveDialog {
        width: parent.width;
        height: parent.height;
        account-remove-open <=> root.account-remove-open;
        operation-loading: root.account-operation-loading;
        operation-stage: root.account-operation-stage;
        operation-error <=> root.account-operation-error;
        account-id: root.managed-account-id;
        account-name: root.managed-account-name;
        account-address: root.managed-account-address;
        remove-account(id) => { root.remove-account(id); }
    }

    if root.filter-menu-open: FilterMenuOverlay {
        width: parent.width;
        height: parent.height;
        navigation-width: root.navigation-width;
        compact-layout: root.compact-layout;
        wide-sidebar: root.wide-sidebar;
        active-folder: root.active-folder;
        filter-menu-open <=> root.filter-menu-open;
        filter-folder(folder) => { root.filter-folder(folder); }
    }

    if root.more-menu-open: InboxMoreMenuOverlay {
        width: parent.width;
        height: parent.height;
        navigation-width: root.navigation-width;
        compact-layout: root.compact-layout;
        wide-sidebar: root.wide-sidebar;
        more-menu-open <=> root.more-menu-open;
        account-menu-open <=> root.account-menu-open;
        settings-open <=> root.settings-open;
    }

    if root.settings-open: SettingsOverlay {
        width: parent.width;
        height: parent.height;
        settings-open <=> root.settings-open;
        dark-mode <=> root.dark-mode;
        high-contrast <=> root.high-contrast;
        reduced-motion <=> root.reduced-motion;
    }

    if root.composer-open: ComposerOverlay {
        width: parent.width;
        height: parent.height;
        compact-layout: root.compact-layout;
        short-window: root.short-window;
        composer-open <=> root.composer-open;
        compose-to <=> root.compose-to;
        compose-subject <=> root.compose-subject;
        compose-body <=> root.compose-body;
        composer-error <=> root.composer-error;
        composer-loading: root.composer-loading;
        composer-status: root.composer-status;
        send-message(to, subject, body) => {
            root.send-message(to, subject, body);
        }
        save-draft(to, subject, body) => {
            root.save-draft(to, subject, body);
        }
    }

    if root.message-menu-open: MessageMenuOverlay {
        width: parent.width;
        height: parent.height;
        compact-layout: root.compact-layout;
        mail-actions-enabled: root.mail-actions-enabled;
        mutation-loading: root.mutation-loading;
        selected-mail: root.selected-mail;
        selected-id: root.selected-id;
        active-folder: root.active-folder;
        message-menu-open <=> root.message-menu-open;
        delete-dialog-open <=> root.delete-dialog-open;
        toggle-star(id) => { root.toggle-star(id); }
        mark-unread(id) => { root.mark-unread(id); }
    }

    if root.delete-dialog-open: DeleteDialog {
        width: parent.width;
        height: parent.height;
        active-folder: root.active-folder;
        selected-id: root.selected-id;
        mail-actions-enabled: root.mail-actions-enabled;
        mutation-loading: root.mutation-loading;
        delete-dialog-open <=> root.delete-dialog-open;
        delete-mail(id) => { root.delete-mail(id); }
    }

    if root.snackbar-visible: Snackbar {
        window-width: root.width;
        window-height: root.height;
        snackbar-text: root.snackbar-text;
        snackbar-can-undo: root.snackbar-can-undo;
        undo-loading: root.undo-loading;
        snackbar-visible <=> root.snackbar-visible;
        undo-delete => { root.undo-delete(); }
    }
}
