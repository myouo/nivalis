import { Theme } from "theme.slint";
import { MButton, MaterialIcon } from "components.slint";

export component EmptyState inherits Rectangle {
    in property <string> title;
    in property <string> detail;
    in property <string> icon;
    in property <string> action-label;
    callback action;

    accessible-role: region;
    accessible-label: title + ". " + detail;
    VerticalLayout {
        alignment: center;
        spacing: 8px;
        MaterialIcon { name: root.icon; height: 38px; size: 26px; icon-color: Theme.on-surface-variant; }
        Text { text: root.title; color: Theme.on-surface; font-family: Theme.body-font; font-size: 14px; font-weight: 500; horizontal-alignment: center; }
        Text { text: root.detail; color: Theme.on-surface-variant; font-family: Theme.body-font; font-size: 11px; horizontal-alignment: center; wrap: word-wrap; }
        MButton { label: root.action-label; variant: "outlined"; clicked => { root.action(); } }
    }
}
