import { ScrollView } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { MailDetail } from "models.slint";
import { MaterialIcon, MIconButton } from "components.slint";
import { ReaderAction } from "actions.slint";
import { EmptyState } from "states.slint";
import { AccountAvatar } from "shared.slint";

export component ReaderPane inherits Rectangle {
    in property <bool> compact-layout: false;
    in property <length> window-width: 1200px;
    in property <bool> mail-actions-enabled: true;
    in property <bool> mutation-loading: false;
    in property <bool> detail-loading: false;
    in property <bool> detail-error: false;
    in property <string> detail-error-title: "";
    in property <string> detail-error-detail: "";
    in property <bool> detail-content-pending: false;
    in property <string> detail-content-error: "";
    in property <string> selected-id: "";
    in property <MailDetail> selected-mail;
    in-out property <bool> detail-open: false;
    in-out property <bool> delete-dialog-open: false;
    in-out property <bool> message-menu-open: false;
    callback filter-folder(string);
    callback toggle-star(string);
    callback archive(string);
    callback mark-unread(string);
    callback retry-detail;

    horizontal-stretch: 1;
    background: Theme.surface;
    accessible-role: complementary;
    accessible-label: "Message reader";

    if !root.compact-layout: Rectangle { x: 0; width: 1px; height: parent.height; background: Theme.outline-variant; }

    if root.detail-loading: Rectangle {
        accessible-role: progress-indicator;
        accessible-label: "Loading message";
        VerticalLayout {
            alignment: center;
            spacing: 8px;
            MaterialIcon { name: "progress_activity"; height: 38px; size: 26px; icon-color: Theme.primary; }
            Text { text: "Loading message..."; color: Theme.on-surface-variant; font-family: Theme.body-font; font-size: 11px; horizontal-alignment: center; }
        }
    }

    if !root.detail-loading && root.detail-error: EmptyState {
        title: root.detail-error-title;
        detail: root.detail-error-detail;
        icon: "warning";
        action-label: "Try again";
        action => { root.retry-detail(); }
    }

    if !root.detail-loading && !root.detail-error && root.selected-id == "": EmptyState {
        title: "Select a message";
        detail: "Choose a conversation from the inbox to read it here.";
        icon: "mail";
        action-label: "Go to inbox";
        action => { root.filter-folder("Inbox"); root.detail-open = false; }
    }

    if !root.detail-loading && !root.detail-error && root.selected-id != "": VerticalLayout {
        spacing: 0px;

        Rectangle {
            height: root.compact-layout ? 0px : 120px;
            visible: !root.compact-layout;
            background: Theme.surface;
        }

        Rectangle {
            height: 68px;
            if !root.compact-layout: Rectangle { y: 0; width: parent.width; height: 1px; background: Theme.outline-variant; }
            Rectangle { y: parent.height - 1px; width: parent.width; height: 1px; background: Theme.outline-variant; }
            HorizontalLayout {
                padding-left: 6px;
                padding-right: 6px;
                spacing: 0px;
                if root.compact-layout: MIconButton { icon: "arrow_back"; label: "Back to message list"; clicked => { root.detail-open = false; } }
                Rectangle { horizontal-stretch: 1; }
                ReaderAction {
                    label: "Archive";
                    icon: "archive";
                    enabled: root.mail-actions-enabled;
                    busy: root.mutation-loading;
                    disabled-reason: "Archive is unavailable while mail is read-only";
                    clicked => { root.archive(root.selected-id); }
                }
                if root.window-width >= 1000px: ReaderAction {
                    width: 76px;
                    label: "Mark unread";
                    icon: "mark_email_unread";
                    enabled: root.mail-actions-enabled;
                    busy: root.mutation-loading;
                    disabled-reason: "Mark unread is unavailable while mail is read-only";
                    clicked => { root.mark-unread(root.selected-id); }
                }
                Rectangle { width: 1px; height: 32px; background: Theme.outline-variant; }
                ReaderAction {
                    width: 64px;
                    icon: "delete";
                    label: "Delete";
                    danger: true;
                    enabled: root.mail-actions-enabled;
                    busy: root.mutation-loading;
                    disabled-reason: "Delete is unavailable while mail is read-only";
                    clicked => { root.delete-dialog-open = true; }
                }
                ReaderAction { width: 58px; icon: "more_horiz"; label: "More"; clicked => { root.message-menu-open = true; } }
            }
        }

        reader-scroll := ScrollView {
            // Mail bodies can contain long URLs, tracking tokens, or other text whose
            // unwrapped preferred width is much wider than the reader. Keep the
            // viewport tied to the visible pane so the content lays out vertically.
            viewport-width: self.visible-width;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

            VerticalLayout {
                width: reader-scroll.visible-width;
                alignment: start;
                padding-left: root.compact-layout ? 18px : 22px;
                padding-right: root.compact-layout ? 18px : 28px;
                padding-top: 18px;
                padding-bottom: 28px;
                spacing: 12px;

                HorizontalLayout {
                    spacing: 8px;
                    Text {
                        text: root.selected-mail.subject;
                        color: Theme.on-surface;
                        font-family: Theme.body-font;
                        font-size: 22px;
                        font-weight: 500;
                        wrap: word-wrap;
                        horizontal-stretch: 1;
                    }
                    Rectangle {
                        width: 54px;
                        height: 24px;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: Theme.outline-variant;
                        background: Theme.surface-container-low;
                        Text { text: root.selected-mail.folder; color: Theme.on-surface-variant; font-family: Theme.body-font; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; overflow: elide; }
                    }
                    MIconButton {
                        icon: root.selected-mail.starred ? "star" : "star_outline";
                        label: !root.mail-actions-enabled ? "Star changes are unavailable while mail is read-only" : root.selected-mail.starred ? "Remove star" : "Add star";
                        selected: root.selected-mail.starred;
                        enabled: root.mail-actions-enabled;
                        busy: root.mutation-loading;
                        clicked => { root.toggle-star(root.selected-id); }
                    }
                    MIconButton { icon: "more_horiz"; label: "More message actions"; clicked => { root.message-menu-open = true; } }
                }

                HorizontalLayout {
                    height: 60px;
                    spacing: 10px;
                    VerticalLayout {
                        width: 42px;
                        height: 60px;
                        alignment: center;
                        AccountAvatar {
                            initials: root.selected-mail.initials;
                            avatar-color: root.selected-mail.avatar-color;
                            avatar-size: 42px;
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        spacing: 1px;
                        horizontal-stretch: 1;
                        Text {
                            text: root.selected-mail.sender;
                            color: Theme.on-surface;
                            font-family: Theme.body-font;
                            font-size: 13px;
                            font-weight: 500;
                            overflow: elide;
                        }
                        Text {
                            text: root.selected-mail.email;
                            color: Theme.on-surface-variant;
                            font-family: Theme.body-font;
                            font-size: 10px;
                            overflow: elide;
                        }
                    }
                    Text { text: root.selected-mail.date; color: Theme.on-surface-variant; font-family: Theme.body-font; font-size: 10px; vertical-alignment: center; }
                    MIconButton { icon: "more_vert"; label: "More sender actions"; compact-visual: true; clicked => { root.message-menu-open = true; } }
                }

                Rectangle { height: 1px; background: Theme.outline-variant; }
                if root.detail-content-pending: Rectangle {
                    height: 64px;
                    border-radius: 6px;
                    background: Theme.surface-container-low;
                    accessible-role: progress-indicator;
                    accessible-label: "Fetching message body in the background";
                    HorizontalLayout {
                        padding-left: 14px;
                        padding-right: 14px;
                        spacing: 10px;
                        MaterialIcon { name: "progress_activity"; width: 24px; size: 20px; icon-color: Theme.primary; }
                        Text {
                            text: "Headers are ready. Fetching the body in the background…";
                            color: Theme.on-surface-variant;
                            font-family: Theme.body-font;
                            font-size: 11px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                    }
                }

                if !root.detail-content-pending && root.detail-content-error != "": Rectangle {
                    height: 68px;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: Theme.outline-variant;
                    background: Theme.surface-container-low;
                    accessible-role: region;
                    accessible-label: root.detail-content-error;
                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 8px;
                        spacing: 8px;
                        MaterialIcon { name: "cloud_off"; width: 24px; size: 19px; icon-color: Theme.on-surface-variant; }
                        Text {
                            text: root.detail-content-error;
                            color: Theme.on-surface-variant;
                            font-family: Theme.body-font;
                            font-size: 10px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            wrap: word-wrap;
                        }
                        MIconButton { icon: "refresh"; label: "Retry loading message body"; clicked => { root.retry-detail(); } }
                    }
                }

                if !root.detail-content-pending && root.detail-content-error == "": VerticalLayout {
                    padding-left: 2px;
                    padding-right: 2px;
                    padding-top: 8px;
                    padding-bottom: 4px;
                    vertical-stretch: 0;

                    body-text := Text {
                        text: root.selected-mail.body == ""
                            ? "This message has no plain-text content."
                            : root.selected-mail.body;
                        color: root.selected-mail.body == "" ? Theme.on-surface-variant : Theme.on-surface;
                        font-family: Theme.body-font;
                        font-size: 14px;
                        font-weight: 400;
                        font-italic: root.selected-mail.body == "";
                        // Character wrapping is the safe fallback for long URLs and
                        // generated tokens that have no word boundaries.
                        wrap: char-wrap;
                        horizontal-alignment: left;
                        vertical-alignment: top;
                        horizontal-stretch: 1;
                        vertical-stretch: 0;
                    }
                }

                if root.selected-mail.body-truncated: Rectangle {
                    height: 52px;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: Theme.outline-variant;
                    background: Theme.surface-container-low;
                    accessible-role: region;
                    accessible-label: "Only a bounded message preview is available";
                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 8px;
                        Text {
                            text: "Only a bounded preview is available until full message loading is connected.";
                            color: Theme.on-surface-variant;
                            font-family: Theme.body-font;
                            font-size: 10px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }
                    }
                }

                if root.selected-mail.has-attachment: Rectangle {
                    width: 392px;
                    horizontal-stretch: 0;
                    height: 52px;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: Theme.outline;
                    background: Theme.surface-container-low;
                    accessible-role: region;
                    accessible-label: "This message contains attachments. Attachment access is not available yet.";
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 9px;
                        MaterialIcon { name: "attach_file"; width: 26px; size: 20px; icon-color: Theme.on-surface-variant; }
                        VerticalLayout {
                            alignment: center;
                            spacing: 1px;
                            horizontal-stretch: 1;
                            Text { text: "This message contains attachments"; color: Theme.on-surface; font-family: Theme.body-font; font-size: 11px; font-weight: 500; overflow: elide; }
                            Text { text: "Attachment access is not available yet"; color: Theme.on-surface-variant; font-family: Theme.body-font; font-size: 9px; }
                        }
                    }
                }

            }
        }
    }
}
