import { Theme } from "theme.slint";
import { MaterialIcon } from "components.slint";

export component ReaderAction inherits Rectangle {
    in property <string> icon;
    in property <string> label;
    in property <string> disabled-reason: "";
    in property <bool> danger: false;
    in property <bool> enabled: true;
    callback clicked;
    forward-focus: focus;

    width: 64px;
    height: 68px;
    border-radius: 4px;
    border-width: focus.has-focus ? 2px : 0px;
    border-color: Theme.focus-ring;
    background: !root.enabled ? transparent : touch.pressed ? Theme.surface-container-highest : touch.has-hover ? Theme.surface-container-high : transparent;
    accessible-role: button;
    accessible-label: !root.enabled && root.disabled-reason != "" ? root.disabled-reason : root.label;
    accessible-enabled: root.enabled;
    accessible-action-default => { if (root.enabled) { root.clicked(); } }

    MaterialIcon {
        x: (parent.width - 20px) / 2;
        y: 9px;
        width: 20px;
        height: 20px;
        name: root.icon;
        size: 17px;
        icon-color: !root.enabled ? Theme.outline : root.danger ? Theme.error : Theme.on-surface-variant;
    }
    Text {
        x: 3px;
        y: 31px;
        width: parent.width - 6px;
        height: 27px;
        text: root.label;
        color: !root.enabled ? Theme.outline : root.danger ? Theme.error : Theme.on-surface;
        font-family: Theme.body-font;
        font-size: 9px;
        font-weight: 400;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }

    focus := FocusScope {
        enabled: root.enabled;
        key-pressed(event) => {
            if (event.text == Key.Return || event.text == Key.Space) { root.clicked(); return accept; }
            return reject;
        }
        touch := TouchArea {
            enabled: root.enabled;
            mouse-cursor: pointer;
            clicked => { focus.focus(); root.clicked(); }
        }
    }
}
