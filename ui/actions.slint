import { Theme } from "theme.slint";
import { MaterialIcon } from "components.slint";

export component ReaderAction inherits Rectangle {
    in property <string> icon;
    in property <string> label;
    in property <string> disabled-reason: "";
    in property <bool> danger: false;
    in property <bool> enabled: true;
    in property <bool> busy: false;
    callback clicked;
    forward-focus: focus;

    width: 64px;
    height: 68px;
    border-radius: 4px;
    background: !root.enabled || root.busy ? transparent : touch.pressed ? Theme.surface-container-highest : touch.has-hover ? Theme.surface-container-high : transparent;
    accessible-role: button;
    accessible-label: root.busy ? root.label + ", loading" : !root.enabled && root.disabled-reason != "" ? root.disabled-reason : root.label;
    accessible-enabled: root.enabled && !root.busy;
    accessible-action-default => { if (root.enabled && !root.busy) { root.clicked(); } }

    MaterialIcon {
        x: (parent.width - 20px) / 2;
        y: 9px;
        width: 20px;
        height: 20px;
        name: root.busy ? "progress_activity" : root.icon;
        size: 17px;
        icon-color: !root.enabled || root.busy ? Theme.outline : root.danger ? Theme.error : Theme.on-surface-variant;
    }
    Text {
        x: 3px;
        y: 31px;
        width: parent.width - 6px;
        height: 27px;
        text: root.label;
        color: !root.enabled || root.busy ? Theme.outline : root.danger ? Theme.error : Theme.on-surface;
        font-family: Theme.body-font;
        font-size: 9px;
        font-weight: 400;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }

    focus := FocusScope {
        enabled: root.enabled && !root.busy;
        key-pressed(event) => {
            if (event.text == Key.Return || event.text == Key.Space) {
                if (root.enabled && !root.busy) { root.clicked(); }
                return accept;
            }
            return reject;
        }
        touch := TouchArea {
            enabled: root.enabled && !root.busy;
            mouse-cursor: pointer;
            clicked => { focus.focus(); root.clicked(); }
        }
    }
}

export component ComposeAction inherits Rectangle {
    in property <bool> compact: false;
    in property <bool> enabled: true;
    in property <string> disabled-reason: "Select one account to compose a message";
    callback clicked;
    forward-focus: focus;

    width: compact ? 48px : 216px;
    height: 48px;
    background: transparent;
    accessible-role: button;
    accessible-label: enabled ? "Compose a new message" : disabled-reason;
    accessible-enabled: enabled;
    accessible-action-default => {
        if (root.enabled) { root.clicked(); }
    }

    Rectangle {
        x: root.compact ? 6px : 0px;
        y: 6px;
        width: root.compact ? 36px : parent.width;
        height: 36px;
        border-radius: 4px;
        background: !root.enabled ? Theme.surface-container-high :
            touch.pressed ? Theme.primary-pressed :
            touch.has-hover ? Theme.primary-hover : Theme.primary;
        animate background { duration: Theme.motion-fast; easing: ease-out; }
    }

    if root.compact: MaterialIcon {
        x: 14px;
        y: 14px;
        width: 20px;
        height: 20px;
        name: "edit";
        size: 17px;
        icon-color: root.enabled ? Theme.on-primary : Theme.outline;
    }

    if !root.compact: HorizontalLayout {
        padding-left: 13px;
        padding-right: 13px;
        spacing: 8px;
        MaterialIcon {
            name: "edit";
            width: 20px;
            size: 17px;
            icon-color: root.enabled ? Theme.on-primary : Theme.outline;
        }
        Text {
            text: "Compose";
            color: root.enabled ? Theme.on-primary : Theme.outline;
            font-family: Theme.body-font;
            font-size: 13px;
            font-weight: 500;
            vertical-alignment: center;
        }
    }

    focus := FocusScope {
        enabled: root.enabled;
        focus-on-tab-navigation: root.enabled;
        key-pressed(event) => {
            if (event.text == Key.Return || event.text == Key.Space) {
                if (root.enabled) { root.clicked(); }
                return accept;
            }
            return reject;
        }
        touch := TouchArea {
            enabled: root.enabled;
            mouse-cursor: pointer;
            clicked => { focus.focus(); root.clicked(); }
        }
    }
}
