export struct AccountItem {
    id: string,
    name: string,
    address: string,
    initials: string,
    unread-count: int,
    status: string,
    avatar-color: color,
    has-error: bool,
}

export struct MailSummary {
    id: string,
    account-id: string,
    account-label: string,
    sender: string,
    initials: string,
    subject: string,
    preview: string,
    time: string,
    unread: bool,
    starred: bool,
    has-attachment: bool,
    avatar-color: color,
}

export struct MailDetail {
    id: string,
    sender: string,
    email: string,
    initials: string,
    subject: string,
    body: string,
    body-truncated: bool,
    date: string,
    folder: string,
    starred: bool,
    has-attachment: bool,
    avatar-color: color,
}

export struct OutboxItem {
    message-id: string,
    account-label: string,
    recipients: string,
    subject: string,
    state: string,
    status: string,
    attempt-detail: string,
}
