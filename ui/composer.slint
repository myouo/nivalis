import { Theme } from "theme.slint";
import {
    LabeledTextField, MButton, MaterialIcon, MIconButton
} from "components.slint";

export component ComposerOverlay inherits FocusScope {
    in property <bool> compact-layout: false;
    in property <bool> short-window: false;
    in-out property <bool> composer-open: false;
    in-out property <string> compose-to: "";
    in-out property <string> compose-subject: "";
    in-out property <string> compose-body: "";
    in-out property <string> composer-error: "";
    in property <bool> composer-loading: false;
    in property <string> composer-status: "";
    callback send-message(string, string, string);
    callback save-draft(string, string, string);
    callback input-edited(string, string);

    z: 30;
    init => { self.focus(); }
    forward-focus: recipient-field;
    key-pressed(event) => {
        if (event.text == Key.Escape) {
            if (!root.composer-loading) {
                root.save-draft(root.compose-to, root.compose-subject, root.compose-body);
            }
            return accept;
        }
        return reject;
    }

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: Theme.scrim;
        accessible-role: form;
        accessible-label: "Compose message";
        accessible-description: root.composer-loading
            ? (root.composer-status != "" ? root.composer-status : "Message operation in progress")
            : "Enter recipients, a subject, and a plain text message";
        TouchArea { }

        Rectangle {
            x: root.compact-layout ? 0px : parent.width - self.width - 18px;
            y: root.compact-layout ? 0px : parent.height - self.height - 18px;
            width: root.compact-layout ? parent.width : 560px;
            height: root.compact-layout ? parent.height : (root.short-window ? parent.height - 24px : 540px);
            border-radius: root.compact-layout ? 0px : 12px;
            border-width: root.compact-layout ? 0px : 1px;
            border-color: Theme.outline;
            background: Theme.surface;

            VerticalLayout {
                padding: root.compact-layout ? 14px : 20px;
                spacing: 8px;

                HorizontalLayout {
                    height: 48px;
                    MIconButton {
                        icon: "close";
                        label: "Save draft and close";
                        busy: root.composer-loading;
                        clicked => {
                            root.save-draft(root.compose-to, root.compose-subject, root.compose-body);
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        spacing: 1px;
                        horizontal-stretch: 1;
                        Text {
                            text: "New message";
                            color: Theme.on-surface;
                            font-family: Theme.body-font;
                            font-size: 18px;
                            font-weight: 500;
                            overflow: elide;
                        }
                        Text {
                            text: root.composer-loading
                                ? (root.composer-status != "" ? root.composer-status : "Message operation in progress")
                                : root.composer-status != "" ? root.composer-status
                                : root.compose-to == "" && root.compose-subject == "" && root.compose-body == ""
                                    ? "New draft"
                                    : "Changes not yet saved";
                            color: root.composer-error != "" ? Theme.error : Theme.on-surface-variant;
                            font-family: Theme.body-font;
                            font-size: 10px;
                            overflow: elide;
                            accessible-role: region;
                            accessible-live-region: polite;
                            accessible-label: self.text;
                        }
                    }
                    MIconButton {
                        icon: root.composer-loading ? "progress_activity" : "more_vert";
                        label: root.composer-loading ? "Message operation in progress" : "More compose options are not available";
                        enabled: false;
                        busy: root.composer-loading;
                    }
                }

                recipient-field := LabeledTextField {
                    label: "Recipients";
                    value <=> root.compose-to;
                    placeholder: "name@example.com";
                    helper: "Separate multiple addresses with commas";
                    enabled: !root.composer-loading;
                    edited(value) => { root.input-edited("to", value); }
                }
                LabeledTextField {
                    label: "Subject";
                    value <=> root.compose-subject;
                    placeholder: "What is this message about?";
                    helper: "Use a concise subject that identifies the conversation";
                    enabled: !root.composer-loading;
                    edited(value) => { root.input-edited("subject", value); }
                }
                LabeledTextField {
                    label: "Message";
                    value <=> root.compose-body;
                    placeholder: "Write your message";
                    helper: "Plain text message";
                    multiline: true;
                    enabled: !root.composer-loading;
                    vertical-stretch: 1;
                    edited(value) => { root.input-edited("body", value); }
                }

                if root.composer-error != "": Rectangle {
                    height: 42px;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: Theme.error;
                    background: Theme.error-container;
                    accessible-role: region;
                    accessible-live-region: assertive;
                    accessible-label: root.composer-error;
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 7px;
                        MaterialIcon {
                            name: "error";
                            width: 18px;
                            size: 16px;
                            icon-color: Theme.error;
                        }
                        Text {
                            text: root.composer-error;
                            color: Theme.on-error-container;
                            font-family: Theme.body-font;
                            font-size: 10px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }
                    }
                }

                HorizontalLayout {
                    height: 50px;
                    spacing: 6px;
                    MIconButton {
                        icon: "attach_file";
                        label: "Add attachment, not available yet";
                        enabled: false;
                    }
                    Text {
                        text: "Plain text";
                        color: Theme.on-surface-variant;
                        font-family: Theme.body-font;
                        font-size: 10px;
                        vertical-alignment: center;
                    }
                    Rectangle { horizontal-stretch: 1; }
                    MButton {
                        min-width: 142px;
                        label: "Send message";
                        icon: "send";
                        variant: "filled";
                        enabled: !root.composer-loading;
                        loading: root.composer-loading;
                        clicked => {
                            root.send-message(root.compose-to, root.compose-subject, root.compose-body);
                        }
                    }
                }
            }
        }
    }
}
